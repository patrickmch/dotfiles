#!/bin/bash
mode="tab"
if [ "$1" = "--vertical" ]; then mode="vertical"; shift; fi
if [ "$1" = "--horizontal" ]; then mode="horizontal"; shift; fi

# Resolve to absolute path
item="$(cd "$1" 2>/dev/null && pwd || echo "$1")"

if [ -d "$item" ]; then
    case "$mode" in
        tab)
            # Extract dir name for tab title (truncate to 20 chars)
            tabname="${item##*/}"
            tabname="${tabname:0:20}"
            # Generate a temp layout with the dir baked into Yazi args
            # (--cwd on new-tab doesn't propagate to command panes)
            tmp="/tmp/cc-workspace-$$.kdl"
            cat > "$tmp" << LAYOUT
layout {
    pane size=1 borderless=true {
        plugin location="tab-bar"
    }
    pane split_direction="vertical" {
        pane size="20%" command="yazi" {
            args "$item"
            name "files"
        }
        pane cwd="$item" name="terminal" {
            focus true
        }
    }
    pane size=1 borderless=true {
        plugin location="status-bar"
    }
}
LAYOUT
            zellij action new-tab --layout "$tmp" --name "$tabname"
            rm -f "$tmp"
            # Close the picker tab if we came from it (CC_PICKER set by cc.kdl)
            if [ -n "$CC_PICKER" ]; then
                zellij action go-to-previous-tab
                zellij action close-tab
            fi
            ;;
        vertical)   zellij action move-focus right; zellij run --direction right --cwd "$item" -- "$SHELL" ;;
        horizontal) zellij action move-focus right; zellij run --direction down --cwd "$item" -- "$SHELL" ;;
    esac
else
    case "$mode" in
        tab)        zellij run --floating --close-on-exit -- nvim "$item" ;;
        vertical)   zellij action move-focus right; zellij run --direction right --close-on-exit -- nvim "$item" ;;
        horizontal) zellij action move-focus right; zellij run --direction down --close-on-exit -- nvim "$item" ;;
    esac
fi
