// Claude Code — project picker
// Launch: cc   (opens Yazi fullscreen, Enter on a dir spawns workspace tab)

layout {
    pane size=1 borderless=true {
        plugin location="tab-bar"
    }
    pane command="yazi" {
        name "picker"
        focus true
    }
    pane size=1 borderless=true {
        plugin location="status-bar"
    }
}
