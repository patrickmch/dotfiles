// Claude Code workspace — Yazi sidebar + terminal
// Spawned by cc-open when entering a project directory

layout {
    pane size=1 borderless=true {
        plugin location="tab-bar"
    }
    pane split_direction="vertical" {
        pane size="20%" command="yazi" {
            name "files"
        }
        pane name="terminal" {
            focus true
        }
    }
    pane size=1 borderless=true {
        plugin location="status-bar"
    }
}
